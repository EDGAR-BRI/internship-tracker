---
import BaseLayout from '../layouts/BaseLayout.astro'
import RegisterForm from '../components/RegisterForm.vue'
---

<BaseLayout title="Crear cuenta - Internship Tracker">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm space-y-6">
      <div class="text-center">
        <h1 class="text-2xl font-semibold tracking-tight">Crear cuenta</h1>
        <p class="text-text-secondary text-sm mt-2">
          Regístrate para empezar a usar el tracker
        </p>
      </div>

      <RegisterForm client:load />

      <p class="text-center text-sm text-text-muted">
        ¿Ya tienes cuenta?
        <a href="/login" class="text-accent hover:text-accent-hover transition-colors">
          Iniciar sesión
        </a>
      </p>
    </div>
  </div>
</BaseLayout>
