---
import BaseLayout from './BaseLayout.astro'
import Navbar from '../components/Navbar.vue'

interface Props {
  title: string
}

const { title } = Astro.props
---

<BaseLayout title={title}>
  <Navbar client:load />
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <slot />
  </main>
</BaseLayout>
