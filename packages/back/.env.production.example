# Node
TZ=UTC
PORT=3333
HOST=0.0.0.0
NODE_ENV=production

# App
LOG_LEVEL=info
APP_KEY=<auto-generated>
APP_URL=https://internship-tracker-api.railway.app

# Session
SESSION_DRIVER=cookie

# Database (Supabase PostgreSQL)
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<your-supabase-password>
DB_DATABASE=postgres

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Frontend URL (for OAuth redirects)
FRONTEND_URL=https://internship-tracker-frontend.vercel.app

# Google OAuth Callback URL
GOOGLE_CALLBACK_URL=https://internship-tracker-api.railway.app/api/v1/auth/google/callback
